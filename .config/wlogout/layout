{
    "label" : "lock",
    "action" : "loginctl lock-session",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "hibernate",
    "action" : "loginctl lock-session && systemctl hibernate",
    "text" : "Hibernate",
    "keybind" : "h"
}
{
    "label" : "logout",
    "action" : "hyprshutdown -t 'Logging out...'",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown -t 'Shutting down...' --post-cmd 'systemctl poweroff'",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "loginctl lock-session && systemctl suspend-then-hibernate",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown -t 'Restarting...' --post-cmd 'systemctl reboot'",
    "text" : "Reboot",
    "keybind" : "r"
}
